{
  "name": "python-wasm-runtime",
  "version": "0.1.0",
  "description": "Python WASM Runtime — CPython compiled to wasm32-wasi, running in the browser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "compile": "node tools/compile-wasm.mjs"
  },
  "devDependencies": {
    "fast-check": "^3.22.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
