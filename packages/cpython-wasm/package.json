{
  "name": "cpython-wasm",
  "version": "0.3.0",
  "description": "CPython 3.13 compiled to WebAssembly (wasm32-wasi) — run Python in the browser",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": "./dist/worker.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/worker.js','dist/worker.js')\"",
    "prepublishOnly": "npm run build",
    "test": "node test/basic.mjs"
  },
  "keywords": ["python", "wasm", "webassembly", "wasi", "cpython", "browser"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
